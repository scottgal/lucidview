    <!-- <PackageReference Include="Mostlylucid.Summarizers.Reader.Gutenberg" Version="*" /> -->
  </ItemGroup>

  <!-- StyloExtract stack (carried from FULL). -->
  <ItemGroup>
    <PackageReference Include="Mostlylucid.StyloExtract.Core" Version="2.0.1" />
    <PackageReference Include="Mostlylucid.StyloExtract.Templates" Version="2.0.1" />
    <PackageReference Include="Mostlylucid.StyloExtract.Streaming" Version="2.0.1" />
    <PackageReference Include="Mostlylucid.StyloExtract.Playwright" Version="2.0.1" />
    <PackageReference Include="Mostlylucid.StyloExtract.Llm.LlamaSharp" Version="2.0.1" />
    <PackageReference Include="Microsoft.Playwright" Version="1.60.0" />
  </ItemGroup>

  <!-- LLM in-process. -->
  <ItemGroup>
    <PackageReference Include="LLamaSharp" Version="0.27.0" />
    <PackageReference Include="LLamaSharp.Backend.Cpu" Version="0.27.0" />
  </ItemGroup>

  <!-- ONNX Runtime + per-platform native packages. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.ML.OnnxRuntime.Managed" Version="1.24.4" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.24.4" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.Gpu" Version="1.24.4" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
    <!-- CoreML EP is part of Microsoft.ML.OnnxRuntime on macOS; no separate package. -->
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.24.4" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
  </ItemGroup>

  <!-- DuckDB + VSS for the vector substrate. -->
  <ItemGroup>
    <PackageReference Include="DuckDB.NET.Bindings.Full" Version="1.5.0" />
    <PackageReference Include="DuckDB.NET.Data.Full" Version="1.5.0" />
  </ItemGroup>

