<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed for an in-flight Mostlylucid.Avalonia.UITesting patch
         (PressKey + KeyEventArgs.Source/KeyUp). Drop this line + bump back
         to the public NuGet version once the patch lands upstream. -->
    <add key="uitest-local" value="/tmp/uitest-local-feed" />
    <!-- Local feed for the in-flight LiveMarkdown.Avalonia HtmlInline/HtmlBlock
         <img> renderer patch (see /Users/<me>/RiderProjects/LiveMarkdown.Avalonia
         feat/html-img-renderer). Drop this line + bump back to the public
         NuGet version once the patch lands upstream. -->
    <add key="livemarkdown-local" value="/tmp/livemarkdown-local-feed" />
  </packageSources>
</configuration>
